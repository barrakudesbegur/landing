---
import { SITE_TITLE } from '../../consts'
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import EventCard from '../../components/EventCard.astro'

const events = (await getCollection('events'))
  .filter((e) => e.data.image)
  .sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf())

const rotations = [
  '-2.5',
  '1.8',
  '-1.2',
  '2.8',
  '-0.5',
  '1.5',
  '-3',
  '0.8',
] as const satisfies string[]
---

<BaseLayout
  title={`Esdeveniments | ${SITE_TITLE}`}
  description={'Tots els nostres esdeveniments, festes i activitats.'}
  class="bg-brand! text-white!"
>
  <main class="px-3 py-12 sm:px-6">
    <h1
      class="font-title mb-10 text-center text-6xl leading-none tracking-wide uppercase sm:text-7xl"
    >
      Esdeveniments
    </h1>

    <div
      class="mx-auto grid max-w-6xl grid-cols-2 items-center gap-3 sm:grid-cols-3 md:grid-cols-4 lg:gap-4"
    >
      {
        events.map((event, i) => (
          <EventCard
            event={event}
            style={`--r: ${rotations[i % 8]}deg`}
            class="rotate-(--r)"
          />
        ))
      }
    </div>
  </main>
</BaseLayout>
