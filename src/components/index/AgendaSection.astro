---
import { getPublicEvents } from '../../lib/events'
import EventTile from './EventTile.astro'

const events = await getPublicEvents()

// Build-time split: an event is upcoming until it has finished.
const now = new Date()
const isUpcoming = (event: (typeof events)[number]) =>
  (event.data.endDate ?? event.data.startDate).valueOf() >= now.valueOf()

// Upcoming: soonest first. Past: most recent first.
const upcoming = events
  .filter(isUpcoming)
  .sort((a, b) => a.data.startDate.valueOf() - b.data.startDate.valueOf())
const past = events
  .filter((event) => !isUpcoming(event))
  .sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf())
---

<div
  class="bg-brand scroll-mt-12 px-3 py-12 text-white sm:px-6"
  id="esdeveniments"
>
  <h2
    class="font-title mb-10 text-center text-5xl leading-none tracking-wide uppercase"
  >
    Esdeveniments
  </h2>

  {
    upcoming.length > 0 && (
      <div class="mx-auto mb-12 max-w-5xl">
        <h3 class="font-title mb-4 text-2xl leading-none tracking-wide text-white/90 uppercase">
          Properament
        </h3>
        <div class="grid grid-cols-2 items-center gap-3 sm:grid-cols-3 md:grid-cols-4 lg:gap-4">
          {upcoming.map((event, i) => (
            <EventTile event={event} index={i} />
          ))}
        </div>
      </div>
    )
  }

  <div class="mx-auto max-w-5xl">
    {
      upcoming.length > 0 && (
        <h3 class="font-title mb-4 text-2xl leading-none tracking-wide text-white/90 uppercase">
          Esdeveniments passats
        </h3>
      )
    }
    <div
      class="grid grid-cols-2 items-center gap-3 sm:grid-cols-3 md:grid-cols-4 lg:gap-4"
    >
      {past.map((event, i) => <EventTile event={event} index={i} />)}
    </div>
  </div>
</div>
