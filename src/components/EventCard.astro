---
import type { CollectionEntry } from 'astro:content'

type Props = {
  event: CollectionEntry<'events'>
  class?: string
  style?: string
}

const { event, class: className, style } = Astro.props
---

<a
  href={`/esdeveniments/${event.id}/`}
  style={style}
  class:list={[
    'block overflow-hidden rounded-sm shadow-md',
    'transition-all duration-300 ease-out',
    'hover:z-10 hover:scale-110 hover:rotate-0 hover:shadow-2xl',
    'focus-visible:z-10 focus-visible:scale-110 focus-visible:rotate-0 focus-visible:ring-4 focus-visible:ring-white/50 focus-visible:outline-none',
    className,
  ]}
>
  <img
    src={event.data.image}
    alt={event.data.title}
    class="block w-full"
    loading="lazy"
  />
</a>
